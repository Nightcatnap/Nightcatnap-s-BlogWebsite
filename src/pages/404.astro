---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 - 页面未找到" description="你似乎迷路了。">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-24 text-center">
    <h1 class="text-6xl font-bold text-[var(--color-accent)] mb-4">404</h1>
    <p class="text-xl text-[var(--color-muted)] mb-8">
      你似乎迷路了，这个页面不存在。
    </p>
    <a
      href="/"
      class="btn-primary inline-block"
    >
      返回首页
    </a>
  </div>
</BaseLayout>
