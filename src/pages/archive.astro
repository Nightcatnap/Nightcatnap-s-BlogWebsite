---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllPosts, sortPosts } from "../utils/posts";

const allPosts = await getAllPosts();
const sorted = sortPosts(allPosts, "date");

// Group by year
const byYear = sorted.reduce(
  (acc, post) => {
    const year = new Date(post.data.date).getFullYear();
    if (!acc.has(year)) acc.set(year, []);
    acc.get(year)!.push(post);
    return acc;
  },
  new Map() as Map<number, typeof sorted>
);
---

<BaseLayout title="归档" description="按年份浏览所有文章。">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="text-3xl font-bold text-[var(--color-text)] mb-8">归档</h1>

    {[...byYear.entries()]
      .sort((a, b) => b[0] - a[0])
      .map(([year, posts]) => (
        <section class="mb-8">
          <h2 class="text-2xl font-bold text-[var(--color-text)] mb-4 sticky top-20 bg-[var(--color-bg)] py-2">
            {year}
          </h2>
          <ul class="space-y-2">
            {posts.map((post) => {
              const displayDate = new Date(post.data.date).toLocaleDateString("zh-CN", {
                month: "2-digit",
                day: "2-digit",
              });
              return (
                <li class="flex items-center gap-4 group">
                  <time class="text-sm text-[var(--color-muted)] shrink-0 w-16" datetime={String(post.data.date)}>
                    {displayDate}
                  </time>
                  <a
                    href={`/posts/${post.slug}`}
                    class="text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors truncate"
                  >
                    {post.data.title}
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      ))}
  </div>
</BaseLayout>
