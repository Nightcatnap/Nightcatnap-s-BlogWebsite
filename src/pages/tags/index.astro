---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllPosts, getTagMap } from "../../utils/posts";

const allPosts = await getAllPosts();
const tagMap = getTagMap(allPosts);
const tags = [...tagMap.entries()].sort((a, b) => b[1].length - a[1].length);
---

<BaseLayout title="标签" description="浏览所有文章标签。">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="text-3xl font-bold text-[var(--color-text)] mb-8">标签</h1>

    {tags.length === 0 ? (
      <p class="text-[var(--color-muted)]">暂无标签。</p>
    ) : (
      <div class="flex flex-wrap gap-3">
        {tags.map(([tag, posts]) => (
          <a
            href={`/tags/${tag}`}
            class="card inline-flex items-center gap-2 px-4 py-3 group"
          >
            <span class="text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors font-medium">
              {tag}
            </span>
            <span class="text-xs text-[var(--color-muted)]">
              {posts.length}
            </span>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
