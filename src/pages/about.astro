---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="关于" description="关于我和这个博客。">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="text-3xl font-bold text-[var(--color-text)] mb-8">关于</h1>

    <div class="prose prose-lg text-[var(--color-text)] space-y-6">
      <p>
        你好！欢迎来到我的个人博客。这里是我记录技术学习、项目经验与生活思考的空间。
      </p>

      <h2 class="text-xl font-semibold mt-8 mb-4">技术栈</h2>
      <div class="flex flex-wrap gap-2">
        <span class="tag-badge">TypeScript</span>
        <span class="tag-badge">React</span>
        <span class="tag-badge">Vue</span>
        <span class="tag-badge">Node.js</span>
        <span class="tag-badge">Python</span>
        <span class="tag-badge">Go</span>
      </div>

      <h2 class="text-xl font-semibold mt-8 mb-4">关于本站</h2>
      <p>
        本站使用 <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)] hover:underline">Astro</a> 构建，
        样式采用 <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)] hover:underline">Tailwind CSS</a>，
        部署在 <a href="https://vercel.com" target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)] hover:underline">Vercel</a> 上。
      </p>

      <h2 class="text-xl font-semibold mt-8 mb-4">联系方式</h2>
      <div class="flex gap-4">
        <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href="mailto:me@example.com" class="text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
