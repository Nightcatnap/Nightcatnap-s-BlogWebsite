---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllPosts } from "../utils/posts";

const allPosts = await getAllPosts();
const postsData = allPosts.map((p) => ({
  slug: p.slug,
  title: p.data.title,
  date: String(p.data.date),
  summary: p.data.summary || "",
  tags: p.data.tags,
}));
---

<BaseLayout title="搜索" description="搜索博客文章。">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="text-3xl font-bold text-[var(--color-text)] mb-8">搜索</h1>

    <div class="mb-8">
      <input
        id="search-input"
        type="text"
        placeholder="输入关键词搜索文章..."
        class="w-full px-4 py-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-card)] text-[var(--color-text)] placeholder-[var(--color-muted)] focus:outline-none focus:border-[var(--color-accent)] transition-colors"
        autocomplete="off"
      />
    </div>

    <div id="search-results" class="space-y-4">
      <p class="text-[var(--color-muted)] text-sm">输入关键词开始搜索。</p>
    </div>
  </div>

  <script id="posts-data" type="application/json">
    {JSON.stringify(postsData)}
  </script>

  <script>
    import Fuse from "fuse.js";

    interface PostData {
      slug: string;
      title: string;
      date: string;
      summary: string;
      tags: string[];
    }

    const dataEl = document.getElementById("posts-data");
    const posts: PostData[] = dataEl ? JSON.parse(dataEl.textContent || "[]") : [];

    const fuse = new Fuse(posts, {
      keys: ["title", "summary", "tags"],
      threshold: 0.3,
      includeMatches: true,
    });

    const input = document.getElementById("search-input") as HTMLInputElement;
    const results = document.getElementById("search-results")!;

    const formatDate = (d: string) => {
      return new Date(d).toLocaleDateString("zh-CN", {
        year: "numeric",
        month: "long",
        day: "numeric",
      });
    };

    input?.addEventListener("input", () => {
      const query = input.value.trim();
      if (!query) {
        results.innerHTML = '<p class="text-[var(--color-muted)] text-sm">输入关键词开始搜索。</p>';
        return;
      }

      const found = fuse.search(query);
      if (found.length === 0) {
        results.innerHTML = '<p class="text-[var(--color-muted)]">没有找到相关文章。</p>';
        return;
      }

      results.innerHTML = found
        .map(
          ({ item }) => `
          <a href="/posts/${item.slug}" class="card block group">
            <h3 class="text-lg font-semibold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">
              ${item.title}
            </h3>
            <time class="text-sm text-[var(--color-muted)] mt-1 block">${formatDate(item.date)}</time>
            <p class="text-sm text-[var(--color-muted)] mt-2 line-clamp-2">${item.summary}</p>
            <div class="flex flex-wrap gap-1 mt-2">
              ${item.tags.map((t) => `<span class="tag-badge text-xs">${t}</span>`).join("")}
            </div>
          </a>
        `
        )
        .join("");
    });
  </script>
</BaseLayout>
