<section class="py-16 sm:py-20 text-center">
  <div class="max-w-2xl mx-auto px-4 sm:px-6">
    <!-- Avatar -->
    <div class="w-24 h-24 sm:w-28 sm:h-28 mx-auto mb-6 rounded-full bg-[var(--color-card)] border-2 border-[var(--color-border)] overflow-hidden">
      <div class="w-full h-full flex items-center justify-center text-3xl text-[var(--color-muted)]">
        <!-- Placeholder avatar, replace with <img> when you have one -->
        <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
      </div>
    </div>

    <!-- Name -->
    <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-text)] mb-3">
      你好，我是...
    </h1>

    <!-- One-liner -->
    <p class="text-lg text-[var(--color-muted)] mb-6 leading-relaxed">
      一个热爱技术、写作与分享的开发者。在这里记录我的学习、思考与生活。
    </p>

    <!-- Interest tags -->
    <div class="flex flex-wrap justify-center gap-2 mb-6">
      <span class="tag-badge">前端开发</span>
      <span class="tag-badge">摄影</span>
      <span class="tag-badge">阅读</span>
      <span class="tag-badge">开源</span>
      <span class="tag-badge">设计</span>
    </div>

    <!-- Social links -->
    <div class="flex justify-center gap-4">
      <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="p-2 text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors" aria-label="GitHub">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
      <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="p-2 text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors" aria-label="Twitter">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href="mailto:me@example.com" class="p-2 text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors" aria-label="Email">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </a>
    </div>
  </div>
</section>
