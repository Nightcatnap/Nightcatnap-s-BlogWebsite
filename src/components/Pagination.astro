---
interface Props {
  current: number;
  total: number;
  base: string;
}

const { current, total, base } = Astro.props;

function pageUrl(page: number): string {
  if (page === 1) return base === "/page" ? "/" : base || "/";
  return `${base}/${page}`;
}
---

{
  total > 1 && (
    <nav class="flex items-center justify-center gap-4 mt-12" aria-label="Pagination">
      {current > 1 && (
        <a
          href={pageUrl(current - 1)}
          class="px-4 py-2 text-sm border border-[var(--color-border)] rounded-lg text-[var(--color-muted)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
        >
          ← 上一页
        </a>
      )}
      <span class="text-sm text-[var(--color-muted)]">
        第 {current} / {total} 页
      </span>
      {current < total && (
        <a
          href={pageUrl(current + 1)}
          class="px-4 py-2 text-sm border border-[var(--color-border)] rounded-lg text-[var(--color-muted)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
        >
          下一页 →
        </a>
      )}
    </nav>
  )
}
